# 区块链网络配置
# =================

# 私钥 (从你的钱包导出，不要包含0x前缀)
PRIVATE_KEY=your_private_key_here

# Polygon 主网 RPC URL (可选，有默认值)
POLYGON_RPC_URL=https://polygon-rpc.com

# Mumbai 测试网 RPC URL (可选，有默认值)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Arbitrum 主网 RPC URL (可选，有默认值)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optimism 主网 RPC URL (可选，有默认值)
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# IPFS 配置
# =========

# Pinata API Key (从 https://app.pinata.cloud/ 获取)
PINATA_API_KEY=your_pinata_api_key

# Pinata Secret API Key (从 https://app.pinata.cloud/ 获取)
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# 合约配置
# ========

# 部署的合约地址 (部署后填写)
CONTRACT_ADDRESS=

# 默认网络 (polygon, mumbai, arbitrum, optimism)
NETWORK=polygon

# 区块浏览器 API Keys
# ===================

# Polygonscan API Key (用于合约验证)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Arbiscan API Key (用于合约验证)
ARBISCAN_API_KEY=your_arbiscan_api_key

# Optimistic Etherscan API Key (用于合约验证)
OPTIMISTIC_ETHERSCAN_API_KEY=your_optimistic_etherscan_api_key

# 部署配置
# ========

# Gas 价格 (可选，使用默认值)
# POLYGON_GAS_PRICE=30000000000
# MUMBAI_GAS_PRICE=30000000000
# ARBITRUM_GAS_PRICE=100000000
# OPTIMISM_GAS_PRICE=1000000

# 开发配置
# ========

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 是否启用详细日志
VERBOSE=false

# 测试配置
# ========

# 测试网络 RPC URL (用于本地测试)
TEST_RPC_URL=http://localhost:8545

# 测试账户私钥 (用于本地测试)
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 